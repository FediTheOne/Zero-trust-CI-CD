# Build artifacts that don't belong in the runtime image
agent.jar
Jenkinsfile
Dockerfile

# Version control metadata (size + history exposure)
.git
.gitignore

# Documentation (no runtime value)
README.md
*.md

# Signing keys — CRITICAL, must never end up in an image
cosign.key
cosign.pub

# Python bytecode caches and local virtualenvs
_pycache_
*.pyc
.venv
venv

# Local environment files (may contain secrets)
.env
.env.local